# Database
DATABASE_PATH=./data/tyreshop.db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# App
PORT=4000
NODE_ENV=development

# Public base URL of this server (used to generate invoice links)
APP_BASE_URL=http://localhost:4000

# Shop details for invoices
SHOP_NAME=TyreShop Pro
SHOP_ADDRESS=123 Main Street, City, State - PINCODE
SHOP_GSTIN=27XXXXX1234F1Z5

# Test database path
TEST_DATABASE_PATH=./data/tyreshop_test.db
