# Database Configuration
# ======================

# PostgreSQL (Railway) - RECOMMENDED for production
DATABASE_URL=postgresql://username:password@host:port/database

# OR SQLite (local development only)
DATABASE_PATH=./data/tyreshop.db

# JWT Configuration
# ==================
JWT_SECRET=your_strong_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# App Configuration
# =================
PORT=4000
NODE_ENV=production

# Public base URL of this server (Railway backend)
# Change this to your Railway URL once deployed
APP_BASE_URL=https://your-app.up.railway.app

# FRONTEND URL (Vercel) - Used for invoice links to work on all networks including Jio
# This should be your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app

# Shop details for invoices
# ========================
SHOP_NAME=SRI MAHALAKSHMI TYRES & Wash
SHOP_PHONE=9000909817
SHOP_ADDRESS=Your shop address here
SHOP_GSTIN=YOUR_GSTIN_HERE

# Railway Database (auto-populated by Railway)
# PGHOST=containers-us-west-123.railway.app
# PGPORT=5432
# PGDATABASE=railway
# PGUSER=postgres
# PGPASSWORD=your_password
